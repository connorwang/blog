---
import { articleKey, type Article } from '../lib/articles';

interface Props {
  article: Article;
}

const { article } = Astro.props;

const formatted = article.data.date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---
<li class="flex items-baseline justify-between gap-4 py-1">
  <a
    href={`/articles/${articleKey(article)}`}
    class="font-body hover:underline decoration-dashed underline-offset-4"
  >
    {article.data.title}
  </a>
  <time
    datetime={article.data.date.toISOString()}
    class="text-sm opacity-60 font-body italic whitespace-nowrap"
  >
    {formatted}
  </time>
</li>
