---
import {
  getAllArticles,
  getArticleVariants,
  articleKey,
  type Article,
} from '../../lib/articles';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const all = await getAllArticles();
  return Promise.all(
    all.map(async (a) => {
      const key = articleKey(a);
      const variants = await getArticleVariants(key);
      return {
        params: { slug: key },
        props: { variants },
      };
    }),
  );
}

interface Props {
  variants: Article[];
}

const { variants } = Astro.props;

const rendered = await Promise.all(
  variants.map(async (a) => ({
    article: a,
    Content: (await a.render()).Content,
  })),
);
---

<ArticleLayout variants={rendered} />
