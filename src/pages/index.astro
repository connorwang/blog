---
import {
  getAllArticles,
  getArticleVariants,
  articleKey,
  type Article,
} from '../lib/articles';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getAllArticles();
const latest = articles[0];

type Rendered = { article: Article; Content: any };
let rendered: Rendered[] = [];
if (latest) {
  const variants = await getArticleVariants(articleKey(latest));
  rendered = await Promise.all(
    variants.map(async (a) => ({
      article: a,
      Content: (await a.render()).Content,
    })),
  );
}
---

{rendered.length > 0 ? (
  <ArticleLayout variants={rendered} />
) : (
  <BaseLayout title="Connor's Blog">
    <div class="mx-auto max-w-prose pt-8 sm:pt-12 pb-6 text-center">
      <p class="opacity-70">No articles yet — check back soon.</p>
    </div>
  </BaseLayout>
)}
